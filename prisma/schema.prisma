// ============================================================
// LIRA DE LUNA — Prisma Schema v3 (MySQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS (customers — NextAuth v5)
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  phone         String?
  whatsappNumber String?
  country       String?  @default("CL")
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  addresses         Address[]
  orders            Order[]
  cart              Cart?
  wishlist          WishlistItem[]
  reviews           Review[]
  newsletter        NewsletterSubscriber?
  resetTokens       PasswordResetToken[]
  pushSubscriptions PushSubscription[]
}

enum UserRole {
  CUSTOMER
  ADMIN
}

// NextAuth v5 — Account (OAuth providers)
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

// NextAuth v5 — Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

// NextAuth v5 — Email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ADMIN USERS (auth separado — JWT httpOnly cookie)
// ============================================================

model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  whatsappNumber String?
  role           AdminRole @default(VIEWER)
  permissions    Json      // string[] — MySQL no soporta arrays nativos
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdById  String?
  createdBy    AdminUser?  @relation("AdminCreatedBy", fields: [createdById], references: [id])
  createdUsers AdminUser[] @relation("AdminCreatedBy")

  auditLogs AuditLog[]

  assignedLeads    Lead[]         @relation("AssignedLeads")
  leadActivities   LeadActivity[] @relation("AdminLeadActivities")
}

enum AdminRole {
  ROOT
  MANAGER
  EDITOR
  VIEWER
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  action      String
  resource    String
  resourceId  String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([resource])
}

// ============================================================
// CATÁLOGO
// ============================================================

enum CollectionType {
  JEWELRY   // Joyería (collares, aretes, anillos, etc.)
  SUPPLIES  // Insumos (líquidos de limpieza, cajitas, empaques, etc.)
  OTHER
}

model Collection {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  description    String?        @db.Text
  image          String?
  collectionType CollectionType @default(JEWELRY)
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  products       Product[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String?  @db.Text
  price          Int      // CLP — sin decimales
  compareAtPrice Int?
  images         Json     // string[] como JSON array
  materials      Json     // string[] como JSON array
  isActive       Boolean  @default(true)
  isNew          Boolean  @default(false)
  isBestseller   Boolean  @default(false)
  sortOrder      Int      @default(0)

  saleType SaleType @default(UNIT)
  stock    Int      @default(0)

  // Ofertas por rango de fecha
  saleEnabled     Boolean   @default(false)
  saleDiscountPct Int?      // porcentaje de descuento 1-99
  saleStartAt     DateTime?
  saleEndAt       DateTime?

  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id])

  variants       ProductVariant[]
  wholesaleTiers WholesaleTier[]
  weightProduct  WeightProduct?
  orderItems     OrderItem[]
  cartItems      CartItem[]
  wishlist       WishlistItem[]
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SaleType {
  UNIT
  WHOLESALE
  WEIGHT
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  label    String
  type     String
  price    Int?
  stock    Int     @default(0)
  sku      String? @unique
  isActive Boolean @default(true)

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model WholesaleTier {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity  Int
  pricePerUnit Int
  sortOrder    Int     @default(0)

  @@unique([productId, minQuantity])
}

model WeightProduct {
  id           String    @id @default(cuid())
  productId    String    @unique
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  metalType    MetalType
  pricePerGram Int
  minGrams     Float     @default(1.0)
  stock        Float     @default(0)
}

enum MetalType {
  ORO_18K
  ORO_14K
  ORO_10K
  PLATA_925
  PLATA_800
  ORO_BLANCO_18K
  ORO_ROSA_18K
}

// ============================================================
// BANNERS / CAROUSEL DE INICIO
// ============================================================

model Banner {
  id        String   @id @default(cuid())
  image     String   @db.Text
  eyebrow   String
  heading   String   @db.Text
  body      String?  @db.Text
  ctaLabel  String   @default("Comprar ahora")
  ctaHref   String   @default("/tienda")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// CARRITO
// ============================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  sessionId String?    @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id          String          @id @default(cuid())
  cartId      String
  cart        Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int
  weightGrams Float?
  addedAt     DateTime        @default(now())

  @@index([cartId, productId, variantId])
}

// ============================================================
// DIRECCIONES & PEDIDOS
// ============================================================

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  name      String
  phone     String?
  street    String
  city      String
  state     String
  zip       String
  country   String  @default("CL")
  isDefault Boolean @default(false)

  orders Order[]
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique

  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  guestEmail String?

  items OrderItem[]

  subtotal       Int
  discountAmount Int @default(0)
  shippingAmount Int @default(0)
  total          Int

  status OrderStatus @default(PENDING)

  paymentStatus     PaymentStatus @default(UNPAID)
  paymentMethod     String?
  mpPreferenceId    String?
  mpPaymentId       String?
  mpMerchantOrderId String?
  mpStatus          String?
  paidAt            DateTime?

  shippingAddressId String?
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  guestName    String?
  guestPhone   String?
  guestStreet  String?
  guestCity    String?
  guestState   String?
  guestZip     String?
  guestCountry String?
  trackingNumber    String?
  carrier           String?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  notes             String?      @db.Text
  channel           OrderChannel @default(ONLINE)
  presencialPayment String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  returns Return[]

  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([guestEmail])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName  String
  variantLabel String?
  saleType     SaleType @default(UNIT)
  quantity     Int
  weightGrams  Float?
  unitPrice    Int
  totalPrice   Int
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum OrderChannel {
  ONLINE
  PRESENCIAL
}

// ============================================================
// DEVOLUCIONES & PÉRDIDAS
// ============================================================

model Return {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id])
  type        ReturnType
  amount      Int?
  description String       @db.Text
  notes       String?      @db.Text
  status      ReturnStatus @default(PENDING)
  adminId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ReturnType {
  PRODUCT_RETURN
  MONEY_REFUND
  DEFECTIVE
  EXCHANGE
}

enum ReturnStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

model LossRecord {
  id          String   @id @default(cuid())
  description String
  amount      Int
  category    String
  notes       String?  @db.Text
  date        DateTime @default(now())
  adminId     String?
  createdAt   DateTime @default(now())
}

// ============================================================
// DESCUENTOS
// ============================================================

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  type           DiscountType
  value          Int
  minOrderAmount Int?
  maxUses        Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  orders         Order[]
  createdAt      DateTime     @default(now())
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

// ============================================================
// WISHLIST
// ============================================================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
}

// ============================================================
// RESEÑAS
// ============================================================

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  body      String?  @db.Text
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// ============================================================
// MARKETING
// ============================================================

model NewsletterSubscriber {
  id     String  @id @default(cuid())
  email  String  @unique
  name   String?
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  isActive     Boolean  @default(true)
  source       String   @default("store")
  subscribedAt DateTime @default(now())

  @@index([isActive])
}

// ============================================================
// CONFIGURACIÓN GLOBAL DE LA TIENDA
// ============================================================

model StoreSettings {
  id               String   @id @default("singleton")
  retailEnabled    Boolean  @default(true)
  wholesaleEnabled Boolean  @default(false)
  logoUrl          String?  @db.Text
  storeName        String   @default("Lira de Luna")
  updatedAt        DateTime @updatedAt

  // Envíos
  freeShippingFrom   Int    @default(30000)
  standardShipping   Int    @default(5990)
  processingDays     String @default("1-2")

  // Métodos de pago
  mercadoPagoEnabled     Boolean @default(false)
  mercadoPagoPublicKey   String? @db.Text
  mercadoPagoAccessToken String? @db.Text

  flowPayEnabled    Boolean @default(false)
  flowPayApiKey     String? @db.Text
  flowPaySecretKey  String? @db.Text

  transferEnabled         Boolean @default(false)
  transferBankName        String?
  transferAccountName     String?
  transferAccountNumber   String?
  transferAccountType     String? // corriente | vista | ahorro
  transferRut             String?
  transferInstructions    String? @db.Text

  // Notificaciones
  notifyNewOrder        Boolean @default(true)
  notifyPaymentFail     Boolean @default(true)
  notifyLowStock        Boolean @default(true)
  notifyWeeklySummary   Boolean @default(false)
  notifyBrowserEnabled  Boolean @default(false)

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text
  seoOgImage     String? @db.Text

  // Email (SMTP)
  emailHost       String?
  emailPort       Int?
  emailSecure     Boolean @default(true)
  emailUser       String?
  emailPassword   String? @db.Text
  emailFromName   String?
  emailFromAddr   String?

  // WhatsApp flotante de contacto
  whatsappContactNumber String?
  whatsappButtonEnabled Boolean @default(false)

  // Web Push Notifications (para clientes)
  pushEnabled          Boolean   @default(false)
  pushVapidPublicKey   String?   @db.Text
  pushVapidPrivateKey  String?   @db.Text
  pushNotifNewProduct  Boolean   @default(true)
  pushNotifLowStock    Boolean   @default(true)
  pushNotifOffers      Boolean   @default(true)
  pushNotifPromo       Boolean   @default(true)
  pushFrequencyPerWeek Int       @default(2)
  pushHourStart        Int       @default(9)
  pushHourEnd          Int       @default(20)
  pushLastSentAt       DateTime?

  // PWA
  pwaCustomerIconUrl  String?   @db.Text
  pwaAdminIconUrl     String?   @db.Text

  // Personalización
  brandColors Json?   // BrandColors: { sand, taupe, dark, cream, beige, beigeLight }
  pageTexts   Json?   // PageTexts: { announcementBar, nosotros, guiaCuidado, guiaCuidadoQuote, privacidad, terminos, preguntas, envios }
  locations   Json    @default("[]") // StoreLocation[]: { id, name, address }

  // Contacto / Soporte
  supportEmail  String?
  supportPhone  String?
}

// ============================================================
// CATÁLOGO — FILTROS GENÉRICOS
// ============================================================

// MATERIAL    → checkbox multi-select, filtra por product.materials[]
// PRICE_RANGE → radio single-select, filtra por rango de precio (minPrice/maxPrice en opciones)
// CUSTOM      → checkbox multi-select, filtra por product.materials[] (para futuros atributos)
enum FilterKind {
  MATERIAL
  PRICE_RANGE
  CUSTOM
}

model FilterGroup {
  id        String         @id @default(cuid())
  name      String
  slug      String         @unique
  kind      FilterKind     @default(CUSTOM)
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  options   FilterOption[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model FilterOption {
  id        String      @id @default(cuid())
  groupId   String
  group     FilterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label     String
  value     String      // para MATERIAL/CUSTOM: debe coincidir con product.materials; para PRICE_RANGE: igual a label
  minPrice  Int?        // solo para PRICE_RANGE
  maxPrice  Int?        // solo para PRICE_RANGE, null = sin límite superior
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
}

// ============================================================
// RECUPERACIÓN DE CONTRASEÑA
// ============================================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ============================================================
// CAMPAÑAS DE EMAIL MARKETING
// ============================================================

model Campaign {
  id        String    @id @default(cuid())
  subject   String
  preheader String?
  content   String    @db.LongText
  imageUrl  String?   @db.Text
  status    String    @default("draft")
  sentCount Int       @default(0)
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ============================================================
// EMAILS TRANSACCIONALES
// ============================================================

model EmailLog {
  id      String    @id @default(cuid())
  to      String
  subject String
  type    EmailType
  orderId String?
  status  String    @default("sent")
  sentAt  DateTime  @default(now())

  @@index([orderId])
  @@index([type])
  @@index([sentAt])
}

enum EmailType {
  ORDER_CONFIRMED
  ORDER_PAID
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  CART_ABANDONED
  WELCOME
  PASSWORD_RESET
  NEWSLETTER
}

// ============================================================
// WEB PUSH — SUSCRIPCIONES DE CLIENTES
// ============================================================

model PushSubscription {
  id         String   @id @default(cuid())
  endpointHash String @unique         // SHA-256 of endpoint for uniqueness
  endpoint   String   @db.Text
  p256dh     String   @db.Text
  auth       String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model PushNotificationLog {
  id        String   @id @default(cuid())
  type      String   // new_product | low_stock | offer | promo
  title     String
  body      String
  url       String?  @db.Text
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
}

// ============================================================
// CRM — LEADS & LANDING PAGES
// ============================================================

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  whatsappNumber  String?
  source          String   @default("MANUAL")
  // source values: MANUAL | LANDING_PAGE | REFERRAL | SOCIAL | OTHER

  landingPageId   String?
  landingPage     LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)

  stage           String   @default("NEW")
  // stage values: NEW | CONTACT_ATTEMPT | CONTACTED | FOLLOW_UP | QUALIFIED | CALL_SCHEDULED | WON | LOST

  tags            Json     @default("[]") // string[]
  notes           String?  @db.Text

  assignedToId    String?
  assignedTo      AdminUser? @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)

  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?

  activities LeadActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([stage])
  @@index([createdAt])
}

model LeadActivity {
  id      String  @id @default(cuid())
  leadId  String
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type    String  // NOTE | CALL | EMAIL | WHATSAPP | STAGE_CHANGE
  content String  @db.Text

  adminId String?
  admin   AdminUser? @relation("AdminLeadActivities", fields: [adminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model LandingPage {
  id       String  @id @default(cuid())
  title    String
  slug     String  @unique
  type     LPType  @default(PROMO)
  isActive Boolean @default(true)
  config   Json
  leads         Lead[]
  registrations EventRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LPType {
  PROMO
  EVENT
}

model EventRegistration {
  id            String   @id @default(cuid())
  landingPageId String
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  ticketCode    String   @unique
  name          String
  email         String
  phone         String?
  whatsapp      String?

  ticketMode    String   @default("FREE")       // FREE | PAID
  paymentMethod String?                          // transfer | mercadoPago | flowPay
  paymentStatus String   @default("CONFIRMED")  // CONFIRMED | PENDING_TRANSFER | PAID | CANCELLED
  amount        Int      @default(0)
  paymentRef    String?
  paymentNotes  String?

  attended      Boolean  @default(false)
  attendedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// COMPRAS A PROVEEDORES
// ============================================================

model Supplier {
  id          String     @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  rut         String?
  address     String?    @db.Text
  notes       String?    @db.Text
  purchases   Purchase[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Purchase {
  id             String                @id @default(cuid())
  purchaseNumber String                @unique
  supplier       Supplier?             @relation(fields: [supplierId], references: [id])
  supplierId     String?
  supplierName   String?
  status         PurchaseStatus        @default(DRAFT)
  paymentStatus  PurchasePaymentStatus @default(UNPAID)
  paymentMethod  String?
  subtotal       Int                   @default(0)
  taxAmount      Int                   @default(0)
  total          Int                   @default(0)
  notes          String?               @db.Text
  orderedAt      DateTime              @default(now())
  expectedAt     DateTime?
  receivedAt     DateTime?
  items          PurchaseItem[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model PurchaseItem {
  id           String   @id @default(cuid())
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId   String
  description  String
  sku          String?
  material     String?              // Plata 925, Oro 18k, Acero 316L, etc.
  purchaseMode String   @default("RETAIL")   // RETAIL | WHOLESALE
  unit         String   @default("pcs")      // pcs | g | kg | oz | ct | lote | m
  quantity     Float
  unitCost     Int
  totalCost    Int
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  PARTIAL
  CANCELLED
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model FinanceAsset {
  id              String        @id @default(cuid())
  name            String
  category        AssetCategory
  purchaseDate    DateTime
  purchaseCost    Int
  usefulLifeYears Int
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum AssetCategory {
  COMPUTER   // Computadores — 3 o 6 años
  SOFTWARE   // Software — 3 años
  FURNITURE  // Muebles y vitrinas — 7 años
  EQUIPMENT  // Equipos y herramientas — 7 años
  VEHICLE    // Vehículos — 7 años
  BUILDING   // Instalaciones/locales — 20 años
  OTHER
}

model RateConfig {
  id          String    @id @default(cuid())
  key         String    @unique  // e.g. "flow.slow", "mp.fast", "iva", "idpc.propyme"
  label       String
  category    String    // "gateway" | "tax"
  value       Float     // base decimal: 0.0289 = 2.89%. Fixed CLP stored as integer float: 202.0
  isPercent   Boolean   @default(true)  // false = valor fijo en CLP
  sourceUrl   String?
  lastChecked DateTime? // última vez que se verificó desde la fuente
  lastChanged DateTime? // última vez que el valor cambió
  prevValue   Float?    // valor anterior antes del último cambio
  notes       String?
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// SECURITY — ISO 27001 A.12.4.1 Event Logging
// ============================================================

model SecurityLog {
  id        String   @id @default(cuid())
  // Tipos: LOGIN_SUCCESS | LOGIN_FAILED | LOGIN_BLOCKED |
  //        ADMIN_LOGIN_SUCCESS | ADMIN_LOGIN_FAILED | ADMIN_LOGIN_BLOCKED |
  //        REGISTER_SUCCESS | REGISTER_BLOCKED | RATE_LIMIT_EXCEEDED |
  //        ACCOUNT_LOCKED | PASSWORD_RESET_REQUEST | PASSWORD_CHANGED
  event     String
  severity  String   @default("INFO")   // INFO | WARNING | ERROR | CRITICAL
  ip        String?
  userAgent String?  @db.Text
  email     String?
  userId    String?
  adminId   String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([ip])
  @@index([email])
  @@index([createdAt])
  @@index([severity, createdAt])
}
